{
  "$schema": "https://dev.cmdocs.sh/schema/docs.json",
  "name": "Next.js",
  "description": "The React framework for production — build full-stack web applications with ease",
  "favicon": "/favicon.svg",
  "seo": {
    "title": "Next.js Documentation",
    "titleTemplate": "%s — Next.js Docs",
    "description": "Learn how to build full-stack web applications with Next.js, the React framework for production.",
    "ogImage": "https://nextjs.org/api/docs-og"
  },
  "theme": {
    "preset": "ocean",
    "darkMode": true,
    "breadcrumb": true,
    "lastUpdated": true
  },
  "navbar": {
    "title": "Next.js",
    "logo": {
      "light": "/logo-light.svg",
      "dark": "/logo-dark.svg",
      "display": "brand-name-and-logo"
    },
    "github": "https://github.com/vercel/next.js",
    "links": [
      {
        "text": "Learn",
        "href": "https://nextjs.org/learn",
        "icon": "GraduationCap",
        "active": "none",
        "external": true
      },
      {
        "type": "icon",
        "text": "X",
        "href": "https://x.com/nextjs",
        "icon": "X",
        "label": "Follow on X",
        "external": true
      },
      {
        "type": "menu",
        "text": "Resources",
        "icon": "MoreHorizontal",
        "items": [
          {
            "text": "Showcase",
            "href": "https://nextjs.org/showcase",
            "description": "Built with Next.js",
            "external": true
          },
          {
            "text": "Blog",
            "href": "https://nextjs.org/blog",
            "description": "Latest news and updates",
            "external": true
          }
        ]
      }
    ]
  },
  "footer": {
    "text": "Built with cmdocs",
    "copyright": "© 2026 Vercel, Inc."
  },
  "navigation": {
    "tabMode": "auto",
    "tabs": [
      {
        "tab": "Documentation",
        "description": "Learn how to build with Next.js",
        "icon": "BookOpen",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Routing",
            "pages": [
              "routing/pages-and-layouts",
              "routing/dynamic-routes",
              "routing/middleware"
            ]
          },
          {
            "group": "Data Fetching",
            "pages": [
              "data-fetching/overview",
              "data-fetching/caching"
            ]
          },
          {
            "group": "Styling",
            "pages": [
              "styling/overview"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "description": "Configuration, route handlers, and utilities",
        "icon": "Code",
        "groups": [
          {
            "group": "API",
            "pages": [
              "api/route-handlers",
              "api/configuration"
            ]
          }
        ]
      },
      {
        "tab": "Deployment",
        "description": "Deploy your Next.js application",
        "icon": "Rocket",
        "groups": [
          {
            "group": "Deployment",
            "pages": [
              "deployment/overview",
              "deployment/docker"
            ]
          }
        ]
      }
    ]
  }
}
